ANTHROPIC_API_KEY=sk-ant-...

# Modal credentials for cloud transcription and diarization (from `modal token new`)
MODAL_TOKEN_ID=ak-...
MODAL_TOKEN_SECRET=as-...

# HS256 signing key for OAuth-issued JWTs gating /mcp.
# auto-generated to ~/.pep-oracle/oauth_signing_key if unset
PEP_ORACLE_OAUTH_SIGNING_KEY=

# Issuer URL in OAuth discovery doc; must match the public tunnel hostname
PEP_ORACLE_PUBLIC_URL=https://pep-oracle.iicapn.com

# Set to 1 ONLY when /oauth/authorize is protected by an upstream authenticator
# like Cloudflare Access; refuses to mount otherwise
PEP_ORACLE_OAUTH_TRUSTS_UPSTREAM_AUTH=1
